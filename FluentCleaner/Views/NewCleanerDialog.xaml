<ContentDialog
    x:Class="FluentCleaner.Views.NewCleanerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    DefaultButton="Primary"
    CornerRadius="8">

    <StackPanel Spacing="4">

        <!-- Type picker -->
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
            <ToggleButton x:Name="btnIni" x:Uid="DlgNewCleanerTypeIni" IsChecked="True" Click="TypeBtn_Click" />
            <ToggleButton x:Name="btnPs1" x:Uid="DlgNewCleanerTypePs1"                    Click="TypeBtn_Click" />
        </StackPanel>

        <!-- Name -->
        <TextBox x:Name="nameBox" Margin="0,0,0,4" />

        <!-- AI generate row (hidden when no API key is configured) -->
        <Grid x:Name="aiRow" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="promptBox"
                     Margin="0,0,6,0" />
            <Button x:Name="generateBtn" x:Uid="DlgNewCleanerGenerate" Grid.Column="1" Click="GenerateBtn_Click" />
        </Grid>

        <!-- Content header: label left, Load template right -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="contentLabel" VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <HyperlinkButton x:Uid="DlgNewCleanerLoadTemplate"
                             Grid.Column="1"
                             Padding="0" Click="TemplateBtn_Click" />
        </Grid>

        <!-- Content editor -->
        <TextBox x:Name="contentBox"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="Consolas"
                 FontSize="12"
                 Height="260"
                 IsSpellCheckEnabled="False"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />

    </StackPanel>
</ContentDialog>
